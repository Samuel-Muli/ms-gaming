# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017
# For local mongo make sure you have downloaded the community edition of MongoDB and have it running on your machine. 
# You can download it from https://www.mongodb.com/try/download/community
# I used the zip version of MongoDB and extracted it to my C drive. 
# Then I ran the following command in the terminal to start the MongoDB server:
# Open a terminal and navigate to the bin folder of your MongoDB installation. 
# For example, if you extracted MongoDB to C:\mongodb, navigate to C:\mongodb\bin.
# Then run ./mongod --dbpath C:\mongodb\data\db
# Make sure also that the dbpath directory exists
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Clerk ───────────────────────────────────────────────────────────────────
# Paste your Clerk keys from https://dashboard.clerk.com/
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# This is also needed server-side for token verification
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Secure Admin Path ───────────────────────────────────────────────────────
# Change this to any secret string — keep it private, never commit the real value
ADMIN_SECRET_PATH=ctrl-panel-x9m2f7
