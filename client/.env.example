VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# ─── Admin path ───────────────────────────────────────────────────────────────
# Not a real security boundary — VITE_ env vars are compiled into the shipped
# JS bundle, so this string is discoverable by anyone who inspects it, no
# matter how obscure it looks. Real access control is the requireAdmin /
# requireMod checks in server.js. This just keeps the panel out of the nav
# and off the well-known default path — generate your own with, e.g.:
#   node -e "console.log(require('crypto').randomBytes(8).toString('hex'))"
# Never commit your real value to git.
VITE_ADMIN_PATH=replace-with-your-own-random-path
