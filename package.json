
{
  "name": "ms-gaming",
  "version": "2.0.0",
  "description": "M S Gaming — PUBG Community & Gaming Hub",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "npm run dev --prefix client",
    "build": "npm install --prefix client && npm run build --prefix client",
    "start": "NODE_ENV=production node server.js"
  },
  "dependencies": {
    "@clerk/backend": "^1.25.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.0",
    "mongodb": "^6.10.0",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "nodemon": "^3.1.0"
  },
  "engines": { "node": ">=18.0.0" }
}
